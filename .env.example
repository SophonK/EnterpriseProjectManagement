# EPM Platform — API environment (copy to .env for local dev; never commit .env)

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (single PostgreSQL, schema per unit) ---
# Schemas: identity, strategy, execution, resource, risk, intake, reporting, shared
DATABASE_URL=postgresql://epm:epm@localhost:5432/epm?schema=shared

# --- OAuth2 / OIDC (enterprise IdP) ---
# For local dev/CI, point these at a mock OIDC issuer (see docker-compose).
OIDC_ISSUER=http://localhost:9000/
OIDC_CLIENT_ID=epm-platform
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_SCOPES=openid profile email roles

# --- Security ---
RATE_LIMIT_AUTH_PER_MIN=20

# Allowed browser origin for the separate web front end (CORS + cookie credentials)
WEB_ORIGIN=http://localhost:5173
