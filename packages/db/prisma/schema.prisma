// EPM Platform — Prisma schema.
// Single PostgreSQL database, one schema per bounded-context unit (+ `shared` for foundation tables).
// Cross-schema writes are forbidden by convention; only `reporting` reads across schemas.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "strategy", "execution", "resource", "risk", "intake", "reporting", "shared"]
}

// ---------------------------------------------------------------------------
// Foundation-owned cross-cutting tables (`shared` schema).
// Domain models are owned by each unit under its own schema.
// ---------------------------------------------------------------------------

/// Immutable audit trail. No app-level UPDATE/DELETE (enforced by DB role + convention).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String // create | update | delete | access_denied
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  before     Json?
  after      Json?
  requestId  String   @map("request_id")
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([occurredAt])
  @@map("audit_log")
  @@schema("shared")
}

/// Transactional outbox — event row committed with the state change, relayed post-commit.
model OutboxEvent {
  eventId     String    @id @map("event_id") @db.Uuid
  eventType   String    @map("event_type")
  payload     Json
  occurredAt  DateTime  @map("occurred_at") @db.Timestamptz(6)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)

  @@index([processedAt])
  @@map("outbox")
  @@schema("shared")
}

/// Idempotency ledger — at-most-once effect per (eventId, handler).
model ProcessedEvent {
  eventId     String   @map("event_id") @db.Uuid
  handler     String
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@id([eventId, handler])
  @@map("processed_events")
  @@schema("shared")
}

// ---------------------------------------------------------------------------
// identity-access unit — `identity` schema (users, RBAC, record scopes)
// ---------------------------------------------------------------------------

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject     String    @unique // IdP `sub`
  email       String?
  displayName String?   @map("display_name")
  status      String    @default("active") // active | inactive
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  roles  UserRole[]
  scopes UserScope[]

  @@map("user")
  @@schema("identity")
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String           @unique // one of the 8 ROLES
  description String?
  permissions RolePermission[]
  users       UserRole[]

  @@map("role")
  @@schema("identity")
}

model Permission {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String           @unique // [domain]:[action]
  description String?
  roles       RolePermission[]

  @@map("permission")
  @@schema("identity")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
  @@schema("identity")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  grantedBy String?  @map("granted_by") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
  @@schema("identity")
}

model UserScope {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  scopeType     String   @map("scope_type") // portfolio | program | project | resource-pool
  scopeId       String?  @map("scope_id") @db.Uuid
  subtreeRootId String?  @map("subtree_root_id") @db.Uuid
  grantedBy     String?  @map("granted_by") @db.Uuid
  grantedAt     DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_scope")
  @@schema("identity")
}
